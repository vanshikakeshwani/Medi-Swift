								{
									"listen": "test",
									"script": {
										"exec": [
											"if (pm.response.code === 200) {",
											"    const responseJson = pm.response.json();",
											"    pm.environment.set('workflow_access_token', responseJson.access);",
											"    pm.environment.set('workflow_user_id', responseJson.user.id);",
											"}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
