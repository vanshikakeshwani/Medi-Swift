										"{{base_url}}"
									],
									"path": [
										"auth",
										"token",
										""
									]
								}
							},
							"response": []
						},
						{
							"name": "Step 3: Get User Profile",
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{workflow_access_token}}"
